###############################################################################
# PH PLUS — Environment variables
###############################################################################
# Copia este archivo a `.env.local` y completá los valores REALES. NO commitees
# `.env.local` — está en .gitignore. Para Vercel, configurá estos mismos valores
# en Settings → Environment Variables.
###############################################################################

# ─── Backend selector ────────────────────────────────────────────────────────
# "mock"     → todo en memoria + localStorage (default, sirve para demo offline)
# "supabase" → usa el proyecto Supabase configurado abajo
NEXT_PUBLIC_DATA_BACKEND=mock

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Conseguilas en Supabase Dashboard → Project Settings → API.
#
# NEXT_PUBLIC_* se exponen al browser — eso está bien para anon key (es la key
# pública pensada para clientes con RLS activo).
#
# SUPABASE_SERVICE_ROLE_KEY NUNCA va con NEXT_PUBLIC_. Solo se usa en server
# components, route handlers, server actions y edge functions. Bypassea RLS,
# tratala como una clave de admin: si se filtra, cualquier persona puede leer
# y modificar todo.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_KEEP_SECRET

# ─── Site URL ────────────────────────────────────────────────────────────────
# Usada para construir links absolutos en emails (recover password, etc).
# En dev: http://localhost:3000
# En Vercel preview: la URL del preview deployment
# En prod: https://www.ph-plus.co (o tu dominio)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Emails transaccionales (Resend) ─────────────────────────────────────────
# Opcional en dev — sin esto los emails se "envían" sólo al outbox de Supabase.
# RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXX
# RESEND_FROM_EMAIL="PH PLUS <hola@ph-plus.co>"

# ─── Plataformas de pago (opcional, para futuro) ─────────────────────────────
# WOMPI_PUBLIC_KEY=
# WOMPI_PRIVATE_KEY=
# MERCADOPAGO_PUBLIC_KEY=
# MERCADOPAGO_ACCESS_TOKEN=
