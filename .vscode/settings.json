{
  "files.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/screenshots": true,
    "**/playwright-report": true,
    "**/test-results": true,
    "**/.turbo": true,
    "**/coverage": true,
    "**/*.tsbuildinfo": true
  },
  "files.watcherExclude": {
    "**/.next/**": true,
    "**/node_modules/**": true,
    "**/screenshots/**": true,
    "**/playwright-report/**": true,
    "**/test-results/**": true,
    "**/.turbo/**": true,
    "**/coverage/**": true,
    "**/.git/**": true
  },
  "search.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/screenshots": true,
    "**/pnpm-lock.yaml": true,
    "**/phplus-screenshots.zip": true,
    "**/*.png": true
  },
  "typescript.tsserver.maxTsServerMemory": 4096,
  "typescript.tsserver.watchOptions": {
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents",
    "excludeDirectories": [
      "**/node_modules",
      "**/.next",
      "**/screenshots"
    ]
  },
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ]
}
